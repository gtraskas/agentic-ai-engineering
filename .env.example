# OpenRouter API key (openrouter.ai/keys) — any LLM through one API
OPENROUTER_API_KEY=

# Optional: override the default chat model (google/gemini-3.1-flash-lite)
OPENROUTER_MODEL=

# Optional: reasoning effort for thinking models (default: low)
ASKGEORGE_REASONING=

# Optional: agent backend ('sdk' default = OpenAI Agents SDK, or 'scratch')
AGENT_BACKEND=

# Optional: set to 0 to disable Qdrant RAG and use full-context mode
ASKGEORGE_RAG=

# Optional: Google Calendar booking-page link (enables the embedded calendar)
CALENDAR_BOOKING_URL=

# Optional: Gmail SMTP for AskGeorge lead/unknown-question notifications.
# Create an App Password: Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
